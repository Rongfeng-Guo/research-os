APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=plain
DATABASE_URL=sqlite:///./research_os.db
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Paper discovery: mock | openalex | arxiv
PAPER_DISCOVERY_PROVIDER=mock
PAPER_DISCOVERY_ALLOW_FALLBACK=true
PAPER_DISCOVERY_TIMEOUT_SECONDS=20
PAPER_SEARCH_LIMIT=8

# Extraction mode: mock | llm
EXTRACTION_PROVIDER=mock
EXTRACTION_ALLOW_FALLBACK=true

# In-process scheduler for automatic refresh
SCHEDULER_ENABLED=true
SCHEDULER_POLL_SECONDS=60
DIGEST_WINDOW_DAYS=7
DATABASE_MIGRATION_MODE=hybrid
OBSIDIAN_EXPORT_DIR=Research OS
# Optional absolute vault root for direct Obsidian file export, for example:
# OBSIDIAN_EXPORT_ROOT=C:\Users\yourname\Documents\ObsidianVault
OBSIDIAN_EXPORT_ROOT=

# Optional digest delivery integrations
# SMTP_HOST=smtp.example.com
SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
# SMTP_TO_EMAILS=team@example.com,archive@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# DIGEST_WEBHOOK_URL=https://example.com/hooks/research-os
DIGEST_WEBHOOK_TIMEOUT_SECONDS=15

# Real OpenAI extraction
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Optional OpenAlex polite pool email
# OPENALEX_EMAIL=
