APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=plain
DATABASE_URL=sqlite:///./data/research_os.db
CORS_ALLOW_ORIGINS=https://research.example.com,https://www.research.example.com

PAPER_DISCOVERY_PROVIDER=mock
PAPER_DISCOVERY_ALLOW_FALLBACK=true
PAPER_DISCOVERY_TIMEOUT_SECONDS=20
PAPER_SEARCH_LIMIT=8

EXTRACTION_PROVIDER=mock
EXTRACTION_ALLOW_FALLBACK=true

SCHEDULER_ENABLED=true
SCHEDULER_POLL_SECONDS=60
DIGEST_WINDOW_DAYS=7
# hybrid: bootstrap legacy pre-Alembic DBs, then run Alembic
# alembic: Alembic only
# lightweight: deprecated emergency legacy runtime ALTER TABLE fallback
DATABASE_MIGRATION_MODE=hybrid
OBSIDIAN_EXPORT_DIR=Research OS
# Optional absolute vault root for direct Obsidian file export.
# OBSIDIAN_EXPORT_ROOT=/srv/obsidian-vault
OBSIDIAN_EXPORT_ROOT=

# Optional digest delivery integrations
# SMTP_HOST=smtp.example.com
SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=ops@example.com
# SMTP_TO_EMAILS=team@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# DIGEST_WEBHOOK_URL=https://hooks.example.com/research-os
DIGEST_WEBHOOK_TIMEOUT_SECONDS=15

# Use a real model only after server-side key management is configured.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENALEX_EMAIL=ops@example.com
